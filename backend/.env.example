# Application Version
APP_VERSION=local-dev

# CORS Settings (comma-separated list of allowed origins)
ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=unshorten_it

# Cache Configuration
# Set REDIS_URL to enable Redis. If empty, it falls back to DiskCache.
# REDIS_URL=redis://localhost:6379
CACHE_EXPIRE_SECONDS=86400

# DiskCache Configuration (fallback if Redis is not available)
DISKCACHE_DIR=/tmp/cacheservice
DISKCACHE_SIZE_LIMIT_MB=500

# Request Settings
REQUEST_TIMEOUT=15.0
